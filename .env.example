# =========================================================================
# PROFPITY LUXURY REAL ESTATE - PRODUCTION ENVIRONMENT CONFIGURATION
# =========================================================================

# -------------------------------------------------------------------------
# BACKEND CONFIGURATION (Deploying on Render with Supabase PostgreSQL)
# -------------------------------------------------------------------------
PORT=5000
NODE_ENV=production

# Database URL - Obtain from Supabase -> Project Settings -> Database -> Connection string (URI)
# Use transaction pooler (port 6543) with ?pgbouncer=true for Prisma client connection pooling.
DATABASE_URL="postgresql://postgres.[YOUR_PROJECT_ID]:[YOUR_PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# JWT Secret - Generate a secure random string
JWT_SECRET="your-super-secure-production-jwt-secret-key"

# Client URL (frontend URL for CORS) - e.g. https://profptiy-luxury.vercel.app
CLIENT_URL="http://localhost:3000"

# SMTP Configuration (Nodemailer setup for contact form and forgot password emails)
# Examples: Mailtrap (dev), SendGrid/Resend/Amazon SES (production)
SMTP_HOST="smtp.resend.com"
SMTP_PORT=587
SMTP_USER="resend"
SMTP_PASS="your-smtp-password"

# Email Notifications Destinations
EMAIL_FROM="noreply@yourdomain.com"
EMAIL_TO="owner@yourdomain.com"


# -------------------------------------------------------------------------
# FRONTEND CONFIGURATION (Deploying on Vercel)
# -------------------------------------------------------------------------
# Backend API URL - e.g. https://profptiy-api.onrender.com/api
NEXT_PUBLIC_API_URL="http://localhost:5000/api"
